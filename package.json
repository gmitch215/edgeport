{
	"name": "edgeport",
	"description": "TCP Library for Cloudflare Workers",
	"version": "1.0.0",
	"type": "module",
	"license": "MIT",
	"author": "Gregory Mitchell",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md", "LICENSE"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./ssh": {
			"types": "./dist/ssh/index.d.ts",
			"import": "./dist/ssh/index.js"
		},
		"./sftp": {
			"types": "./dist/sftp/index.d.ts",
			"import": "./dist/sftp/index.js"
		},
		"./smtp": {
			"types": "./dist/smtp/index.d.ts",
			"import": "./dist/smtp/index.js"
		},
		"./imap": {
			"types": "./dist/imap/index.d.ts",
			"import": "./dist/imap/index.js"
		},
		"./pop3": {
			"types": "./dist/pop3/index.d.ts",
			"import": "./dist/pop3/index.js"
		},
		"./ws": {
			"types": "./dist/ws/index.d.ts",
			"import": "./dist/ws/index.js"
		},
		"./nats": {
			"types": "./dist/nats/index.d.ts",
			"import": "./dist/nats/index.js"
		},
		"./mqtt": {
			"types": "./dist/mqtt/index.d.ts",
			"import": "./dist/mqtt/index.js"
		},
		"./stomp": {
			"types": "./dist/stomp/index.d.ts",
			"import": "./dist/stomp/index.js"
		},
		"./ftp": {
			"types": "./dist/ftp/index.d.ts",
			"import": "./dist/ftp/index.js"
		},
		"./ldap": {
			"types": "./dist/ldap/index.d.ts",
			"import": "./dist/ldap/index.js"
		},
		"./ldaps": {
			"types": "./dist/ldaps/index.d.ts",
			"import": "./dist/ldaps/index.js"
		},
		"./syslog": {
			"types": "./dist/syslog/index.d.ts",
			"import": "./dist/syslog/index.js"
		},
		"./wire": {
			"types": "./dist/wire.d.ts",
			"import": "./dist/wire.js"
		},
		"./crypto": {
			"types": "./dist/crypto/index.d.ts",
			"import": "./dist/crypto/index.js"
		},
		"./kex": {
			"types": "./dist/kex/index.d.ts",
			"import": "./dist/kex/index.js"
		},
		"./auth": {
			"types": "./dist/auth/index.d.ts",
			"import": "./dist/auth/index.js"
		}
	},
	"scripts": {
		"build": "bun run build.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:report": "vitest run --reporter=junit --outputFile=test-report.junit.xml",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "INTEGRATION=1 vitest run",
		"test:e2e:coverage": "INTEGRATION=1 vitest run --coverage",
		"docs:build": "typedoc",
		"docs:serve": "typedoc --watch",
		"prettier": "bunx prettier --write .",
		"prettier:check": "bunx prettier --check .",
		"prepare": "husky install"
	},
	"dependencies": {
		"@noble/ciphers": "^2.2.0",
		"bcrypt-pbkdf": "^1.0.2"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.20",
		"@cloudflare/workers-types": "^4.20260629.1",
		"@types/bun": "^1.3.14",
		"@vitest/coverage-istanbul": "^4.1.9",
		"husky": "^9.1.7",
		"prettier": "^3.9.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9",
		"wrangler": "^4.105.0"
	},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gmitch215/edgeport.git"
  },
  "bugs": {
    "url": "https://github.com/gmitch215/edgeport/issues"
  },
  "homepage": "https://github.com/gmitch215/edgeport#readme",
	"lint-staged": {
		"*.{js,ts,json,yml,md}": "prettier --write"
	}
}
